<launch>
  <node pkg="swarmy_display" type="emotion_state_node.py" name="emotion_state_node" output="screen">
    <param name="timeout" value="1.5"/>
    <param name="move_cmd_threshold" value="0.02"/>
    <param name="move_odom_threshold" value="0.01"/>
    <param name="move_joint_threshold" value="0.001"/>
  </node>
</launch>
