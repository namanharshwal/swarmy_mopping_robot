<launch>
  <arg name="rviz" default="true"/>
  <arg name="teleop" default="false"/>

  <param name="robot_description" textfile="$(find Swarmy_Bot_URDF)/urdf/Swarmy_Bot_URDF.urdf"/>

  <node pkg="robot_state_publisher"
        type="robot_state_publisher"
        name="robot_state_publisher"
        output="screen"/>

  <node pkg="tf"
        type="static_transform_publisher"
        name="basefoot_to_base"
        args="0 0 0 0 0 0 base_footprint base_link 50"/>

  <node pkg="tf"
        type="static_transform_publisher"
        name="base_to_imu"
        args="0 0 0.05 0 0 0 base_link imu_link 50"/>

  <node pkg="swarmy_cmd_vel"
        type="swarmy_base_node.py"
        name="swarmy_base_node"
        output="screen"/>

  <include file="$(find ydlidar_ros_driver)/launch/G2.launch"/>

  <node pkg="robot_localization"
        type="ekf_localization_node"
        name="ekf_localization_node"
        clear_params="true"
        output="screen">
    <rosparam command="load" file="$(find Swarmy_Bot_URDF)/config/ekf.yaml"/>
  </node>

  <node if="$(arg teleop)"
        pkg="teleop_twist_keyboard"
        type="teleop_twist_keyboard.py"
        name="teleop"
        output="screen"
        launch-prefix="xterm -e"/>

  <node if="$(arg rviz)"
        pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find Swarmy_Bot_URDF)/rviz/swarmy.rviz"/>
</launch>
