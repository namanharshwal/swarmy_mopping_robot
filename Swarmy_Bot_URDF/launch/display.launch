<launch>
  <param name="robot_description" textfile="$(find Swarmy_Bot_URDF)/urdf/Swarmy_Bot_URDF.urdf"/>
  <node pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" name="joint_state_publisher_gui"/>
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>
  <node pkg="tf" type="static_transform_publisher" name="base_to_footprint" args="0 0 0 0 0 0 base_footprint base_link 50"/>
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find Swarmy_Bot_URDF)/rviz/swarmy.rviz"/>
</launch>
