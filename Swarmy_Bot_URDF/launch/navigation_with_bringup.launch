<launch>
  <arg name="map_file" default="$(env HOME)/swarmy_ws/maps/hostel_room_map.yaml"/>
  <include file="$(find Swarmy_Bot_URDF)/launch/swarmy_industrial_bringup.launch"/>
  <include file="$(find Swarmy_Bot_URDF)/launch/navigation.launch">
    <arg name="map_file" value="$(arg map_file)"/>
  </include>
</launch>
