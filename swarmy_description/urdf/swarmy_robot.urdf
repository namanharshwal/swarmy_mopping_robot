<?xml version="1.0"?>
<robot name="swarmy_robot">

  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="dark_gray"><color rgba="0.25 0.25 0.25 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.3 0.8 1.0"/></material>
  <material name="silver"><color rgba="0.75 0.75 0.75 1.0"/></material>

  <link name="base_footprint">
    <visual><geometry><box size="0.001 0.001 0.001"/></geometry></visual>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.200 0.155 0.080"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.200 0.155 0.080"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.001477" ixy="0.0" ixz="0.0"
               iyy="0.002363" iyz="0.0" izz="0.003303"/>
    </inertial>
  </link>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.05" length="0.045"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.05" length="0.045"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000228" ixy="0.0" ixz="0.0"
               iyy="0.000228" iyz="0.0" izz="0.000188"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel_link"/>
    <origin xyz="0.0 -0.100 -0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>

  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.05" length="0.045"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.05" length="0.045"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.000228" ixy="0.0" ixz="0.0"
               iyy="0.000228" iyz="0.0" izz="0.000188"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel_link"/>
    <origin xyz="0.0 0.100 -0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>

  <link name="caster_fr_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.015"/></geometry>
    </collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0000045" ixy="0.0" ixz="0.0"
               iyy="0.0000045" iyz="0.0" izz="0.0000045"/>
    </inertial>
  </link>
  <joint name="caster_fr_joint" type="fixed">
    <parent link="base_link"/><child link="caster_fr_link"/>
    <origin xyz="0.075 -0.055 -0.035" rpy="0 0 0"/>
  </joint>

  <link name="caster_fl_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.015"/></geometry>
    </collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0000045" ixy="0.0" ixz="0.0"
               iyy="0.0000045" iyz="0.0" izz="0.0000045"/>
    </inertial>
  </link>
  <joint name="caster_fl_joint" type="fixed">
    <parent link="base_link"/><child link="caster_fl_link"/>
    <origin xyz="0.075 0.055 -0.035" rpy="0 0 0"/>
  </joint>

  <link name="caster_rr_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.015"/></geometry>
    </collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0000045" ixy="0.0" ixz="0.0"
               iyy="0.0000045" iyz="0.0" izz="0.0000045"/>
    </inertial>
  </link>
  <joint name="caster_rr_joint" type="fixed">
    <parent link="base_link"/><child link="caster_rr_link"/>
    <origin xyz="-0.075 -0.055 -0.035" rpy="0 0 0"/>
  </joint>

  <link name="caster_rl_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0">
      </origin><geometry><sphere radius="0.015"/></geometry>
    </collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0000045" ixy="0.0" ixz="0.0"
               iyy="0.0000045" iyz="0.0" izz="0.0000045"/>
    </inertial>
  </link>
  <joint name="caster_rl_joint" type="fixed">
    <parent link="base_link"/><child link="caster_rl_link"/>
    <origin xyz="-0.075 0.055 -0.035" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.040"/></geometry>
      <material name="black"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.038" length="0.040"/></geometry>
    </collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.0000358" ixy="0.0" ixz="0.0"
               iyy="0.0000358" iyz="0.0" izz="0.0000722"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.080" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.025 0.060 0.020"/></geometry>
      <material name="silver"/>
    </visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.025 0.060 0.020"/></geometry>
    </collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="0.0000018" ixy="0.0" ixz="0.0"
               iyy="0.0000007" iyz="0.0" izz="0.0000024"/>
    </inertial>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/><child link="camera_link"/>
    <origin xyz="0.1125 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/><child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

</robot>
